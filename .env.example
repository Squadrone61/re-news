COMPOSE_PROJECT_NAME=re-news

# Postgres password for the `newsletter` user. Used by db, web, worker, migrate, backup.
DB_PASSWORD=change-me

# iron-session signing secret — must be ≥32 chars.
# Generate with: openssl rand -hex 32
SESSION_PASSWORD=replace-with-at-least-32-random-characters

# Gmail sender credentials are NOT stored in env. Configure them at /settings
# (admin-only) after creating the first user via /setup.
