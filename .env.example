COMPOSE_PROJECT_NAME=re-news

# Postgres
DB_PASSWORD=change-me

# iron-session (≥32 chars; generate with: openssl rand -hex 32)
SESSION_PASSWORD=replace-with-at-least-32-random-characters

# First admin hint; NOT env-seeded. Create the admin via /setup.
ADMIN_EMAIL=admin@example.com

# Gmail (used in plan 5 via Settings UI, not env — placeholders for now)
GMAIL_USER=
GMAIL_APP_PASSWORD=
