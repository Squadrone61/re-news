{
  "name": "@renews/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    },
    "./researchSummary": {
      "types": "./dist/researchSummary.d.ts",
      "import": "./dist/researchSummary.js"
    }
  },
  "scripts": {
