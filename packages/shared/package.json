    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.22.0",
    "cron-parser": "^5.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
